generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  USER
  ADMIN
}

enum AuthProvider {
  EMAIL
  GOOGLE
}

model User {
  id           String       @id @db.Uuid
  name         String
  email        String       @unique
  role         Role         @default(USER)
  authProvider AuthProvider
  createdAt    DateTime     @default(now())
}
