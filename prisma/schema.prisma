generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  USER
  ADMIN
}

enum Plan {
  FREE
  PRO
  ENTERPRISE
}

enum ChatRole {
  USER
  ASSISTANT
}

enum CaseFileKind {
  IMAGE
  DOCUMENT
}

enum AuthProvider {
  EMAIL
  GOOGLE
}

enum CaseStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

enum CaseCategory {
  FAMILY_LAW
  PROPERTY_LAW
  EMPLOYMENT_LAW
  CORPORATE_LAW
  COMMERCIAL_LAW
  CRIMINAL_LAW
  CIVIL_LAW
  IMMIGRATION_LAW
  CONSUMER_DISPUTE
  OTHER
}

enum ImmigrationSubcategory {
  STUDENT_VISA
  WORK_VISA
  PERMANENT_RESIDENCY
  CITIZENSHIP
  VISITOR_VISA
  PARTNER_VISA
  EMPLOYER_SPONSORSHIP
  APPEAL
  OTHER
}

model User {
  id           String       @id @db.Uuid
  fullName     String
  email        String       @unique
  role         Role         @default(USER)
  plan         Plan         @default(FREE)
  authProvider AuthProvider
  lastActiveAt DateTime?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  cases        Case[]
  usage        DailyUsage[]
}

model Case {
  id               String       @id @default(uuid()) @db.Uuid
  userId           String       @db.Uuid
  user             User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  title            String
  status           CaseStatus   @default(ACTIVE)
  summary          String?
  summaryUpdatedAt DateTime?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
  intake           CaseIntake?
  messages         ChatMessage[]
  files            CaseFile[]

  @@index([userId, createdAt(sort: Desc)])
  @@map("cases")
}

model CaseIntake {
  id          String                  @id @default(uuid()) @db.Uuid
  caseId      String                  @unique @db.Uuid
  case        Case                    @relation(fields: [caseId], references: [id], onDelete: Cascade)
  category    CaseCategory
  subcategory ImmigrationSubcategory?
  description String
  createdAt   DateTime                @default(now())
  updatedAt   DateTime                @updatedAt

  @@map("case_intakes")
}

model ChatMessage {
  id           String   @id @default(uuid()) @db.Uuid
  caseId       String   @db.Uuid
  case         Case     @relation(fields: [caseId], references: [id], onDelete: Cascade)
  role         ChatRole
  content      String
  inputTokens  Int?
  outputTokens Int?
  createdAt    DateTime @default(now())

  @@index([caseId, createdAt])
  @@map("chat_messages")
}

/**
 * Case-level knowledge file (image or document) — uploaded once, used as
 * context for every assistant turn on the case, not attached per-message.
 */
model CaseFile {
  id          String       @id @default(uuid()) @db.Uuid
  caseId      String       @db.Uuid
  case        Case         @relation(fields: [caseId], references: [id], onDelete: Cascade)
  uploadedBy  String       @db.Uuid
  fileName    String
  mimeType    String
  sizeBytes   Int
  storagePath String
  kind        CaseFileKind
  createdAt   DateTime     @default(now())

  @@index([caseId, createdAt])
  @@map("case_files")
}

model DailyUsage {
  id           String   @id @default(uuid()) @db.Uuid
  userId       String   @db.Uuid
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  day          DateTime @db.Date
  messageCount Int      @default(0)
  inputTokens  Int      @default(0)
  outputTokens Int      @default(0)

  @@unique([userId, day])
  @@map("daily_usage")
}
