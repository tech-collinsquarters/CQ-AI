# Supabase public client configuration
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only Supabase credential (never expose with NEXT_PUBLIC_)
SUPABASE_SERVICE_ROLE_KEY=

# Runtime uses the Supabase transaction-mode pooler (normally port 6543).
DATABASE_URL=
# Prisma migrations use the direct/session connection (normally port 5432).
DIRECT_URL=
# Maximum PostgreSQL connections per application instance.
DATABASE_POOL_MAX=3

# Amazon Bedrock. In production, prefer an IAM workload role and omit static
# access keys. Local development may use a scoped IAM access key.
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
BEDROCK_MODEL_ID=anthropic.claude-opus-4-8

# Branding used in AI prompts and quota messages
FIRM_NAME=Collins Quarters
FIRM_WEBSITE_URL=https://collinsquarters.com
